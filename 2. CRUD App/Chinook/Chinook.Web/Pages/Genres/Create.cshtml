@page
@model Chinook.Web.Pages.Genres.CreateModel
@{
    ViewData["Title"] = "Create Genre";
}
<h1>Create Genre</h1>
<form method="post">
    <div class="mb-3">
        <label asp-for="Genre.Name" class="form-label"></label>
        <input asp-for="Genre.Name" class="form-control" />
        <span asp-validation-for="Genre.Name" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Create</button>
    <a asp-page="Index" class="btn btn-secondary">Back to list</a>
</form>
