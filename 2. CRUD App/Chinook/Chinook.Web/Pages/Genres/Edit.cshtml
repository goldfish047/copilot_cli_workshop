@page
@model Chinook.Web.Pages.Genres.EditModel
@{
    ViewData["Title"] = "Edit Genre";
}
<h1>Edit</h1>
<form method="post">
    <input type="hidden" asp-for="Genre.GenreId" />
    <div class="mb-3">
        <label asp-for="Genre.Name" class="form-label"></label>
        <input asp-for="Genre.Name" class="form-control" />
        <span asp-validation-for="Genre.Name" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-page="Index" class="btn btn-secondary">Back to list</a>
</form>
